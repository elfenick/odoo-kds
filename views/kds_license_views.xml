<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_kds_license_form" model="ir.ui.view">
        <field name="name">kds.license.form</field>
        <field name="model">kds.license</field>
        <field name="arch" type="xml">
            <form string="Licencia KDS" create="false" delete="false">
                <sheet>
                    <div class="oe_title"><h1>Licencia Bitópolis KDS</h1></div>
                    <group>
                        <field name="license_key" widget="text"
                               class="o_kds_license_censored"
                               placeholder="Pega aquí tu código de licencia..."/>
                        <field name="status" readonly="1"/>
                        <field name="valid" readonly="1"/>
                    </group>
                    <div style="margin-top: 16px;">
                        <button name="action_validate" type="object"
                                string="✅ Validar Licencia" class="btn-primary"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_kds_license" model="ir.actions.act_window">
        <field name="name">Licencia KDS</field>
        <field name="res_model">kds.license</field>
        <field name="view_mode">form</field>
        <field name="context">{"create": True}</field>
    </record>

    <record id="action_kds_license_server" model="ir.actions.server">
        <field name="name">Licencia KDS</field>
        <field name="model_id" ref="model_kds_license"/>
        <field name="state">code</field>
        <field name="code">action = env['kds.license'].action_open_license()</field>
    </record>

    <menuitem id="menu_kds_license" name="Licencia"
              parent="menu_kds_root" action="action_kds_license_server"
              sequence="30" groups="base.group_system"/>
</odoo>
