<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================================================================
         DASHBOARD CLIENT ACTION
    ================================================================= -->
    <record id="action_kds_dashboard" model="ir.actions.client">
        <field name="name">Cocina KDS</field>
        <field name="tag">bitopolis_kds.dashboard</field>
    </record>

    <!-- Eliminar explícitamente la acción URL antigua que abría /kds/ui -->
    <delete model="ir.actions.act_url" search="[('url','=','/kds/ui')]"/>

    <!-- ================================================================
         ESTACIONES
    ================================================================= -->
    <record id="view_kds_station_list" model="ir.ui.view">
        <field name="name">kds.station.list</field>
        <field name="model">kds.station</field>
        <field name="arch" type="xml">
            <list string="Estaciones KDS" editable="top" create="0" delete="0">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="pos_category_ids" widget="many2many_tags"/>
                <field name="show_all"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_kds_station_form" model="ir.ui.view">
        <field name="name">kds.station.form</field>
        <field name="model">kds.station</field>
        <field name="arch" type="xml">
            <form string="Estación KDS">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nombre de estación..."/></h1>
                    </div>
                    <group>
                        <group string="Filtro de Categorías">
                            <field name="show_all"/>
                            <field name="pos_category_ids" widget="many2many_tags"
                                   invisible="show_all"/>
                        </group>
                        <group string="General">
                            <field name="sequence"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert" invisible="show_all">
                        <strong>Tip:</strong> Asigna categorías para filtrar qué
                        productos aparecen en esta pantalla. Los productos sin
                        categoría POS aparecen en <strong>todas</strong> las estaciones.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_kds_stations" model="ir.actions.act_window">
        <field name="name">Estaciones KDS</field>
        <field name="res_model">kds.station</field>
        <field name="view_mode">list,form</field>
        <field name="context">{"create": False}</field>
    </record>

    <!-- ================================================================
         HISTORIAL DE ÓRDENES
    ================================================================= -->
    <record id="view_kds_order_tree" model="ir.ui.view">
        <field name="name">kds.order.list</field>
        <field name="model">kds.order</field>
        <field name="arch" type="xml">
            <list string="KDS Orders"
                  decoration-success="state=='done'"
                  decoration-warning="state=='pending'">
                <field name="name"/>
                <field name="tracking_number"/>
                <field name="table_name"/>
                <field name="config_id"/>
                <field name="sent_at"/>
                <field name="done_at"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_kds_order_form" model="ir.ui.view">
        <field name="name">kds.order.form</field>
        <field name="model">kds.order</field>
        <field name="arch" type="xml">
            <form string="KDS Order">
                <header>
                    <button name="action_done" type="object" string="Marcar Listo"
                            class="oe_highlight" invisible="state != 'pending'"/>
                    <button name="action_reopen" type="object" string="Reabrir"
                            invisible="state == 'pending'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="tracking_number"/>
                            <field name="table_name"/>
                        </group>
                        <group>
                            <field name="pos_order_id"/>
                            <field name="config_id"/>
                            <field name="sent_at"/>
                            <field name="done_at"/>
                        </group>
                    </group>
                    <field name="note" placeholder="Nota general..."/>
                    <field name="line_ids">
                        <list editable="bottom">
                            <field name="product_id"/>
                            <field name="qty"/>
                            <field name="attribute_value_names"/>
                            <field name="note"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_kds_order_admin" model="ir.actions.act_window">
        <field name="name">Historial KDS</field>
        <field name="res_model">kds.order</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ================================================================
         MENÚS
         El menú raíz usa action_kds_dashboard (client action = dashboard OWL).
         Al hacer click en "Cocina" abre el dashboard, NO /kds/ui.
    ================================================================= -->
    <menuitem id="menu_kds_root"
              name="Cocina"
              web_icon="bitopolis_kds,static/description/icon.png"
              action="action_kds_dashboard"
              sequence="55"/>

    <menuitem id="menu_kds_stations"
              name="Estaciones"
              parent="menu_kds_root"
              action="action_kds_stations"
              sequence="10"
              groups="point_of_sale.group_pos_manager"/>

    <menuitem id="menu_kds_orders"
              name="Historial de Órdenes"
              parent="menu_kds_root"
              action="action_kds_order_admin"
              sequence="20"
              groups="point_of_sale.group_pos_manager"/>

</odoo>
