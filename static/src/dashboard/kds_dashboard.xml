<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="bitopolis_kds.Dashboard">
    <div class="o_kds_dashboard">

        <!-- =================== HERO ======================== -->
        <div class="o_kds_dash_hero">
            <div class="o_kds_dash_hero_left">
                <div class="o_kds_dash_hero_icon">🍳</div>
                <div class="o_kds_dash_hero_text">
                    <h1>Bitópolis KDS</h1>
                    <p>Kitchen Display System — Panel de Control</p>
                </div>
            </div>
            <div class="o_kds_dash_hero_stats">
                <div class="o_kds_dash_stat">
                    <span class="o_kds_dash_stat_num"
                          t-att-class="'o_kds_dash_stat_num ' + pendingClass"
                          t-esc="state.totalPending"/>
                    <span class="o_kds_dash_stat_label">Pendientes</span>
                </div>
                <div class="o_kds_dash_stat">
                    <span class="o_kds_dash_stat_num o_kds_ok"
                          t-esc="state.stations.length"/>
                    <span class="o_kds_dash_stat_label">Estaciones</span>
                </div>
            </div>
        </div>

        <!-- =================== BODY ======================== -->
        <div class="o_kds_dash_body">

            <!-- Loading -->
            <div t-if="state.loading" class="o_kds_dash_loading">
                <span>⏳</span> Cargando...
            </div>

            <t t-else="">

                <!-- ========= ESTACIONES ========= -->
                <div class="o_kds_dash_section">
                    <div class="o_kds_dash_section_header">
                        <h2 class="o_kds_dash_section_title">📺 Estaciones</h2>
                        <t t-if="state.licenseValid">
                            <button class="o_kds_dash_section_action"
                                    t-on-click="openStationsList">
                                Gestionar estaciones →
                            </button>
                        </t>
                        <t t-else="">
                            <span class="o_kds_demo_lock_btn_sm">🔒 Gestionar estaciones</span>
                        </t>
                    </div>

                    <div class="o_kds_dash_station_grid">

                        <!-- Tarjeta por estación -->
                        <t t-foreach="state.stations" t-as="station" t-key="station.id">
                            <div class="o_kds_dash_station_card">
                                <div class="o_kds_dash_station_card_top">
                                    <div class="o_kds_dash_station_card_icon_row">
                                        <div class="o_kds_dash_station_icon">📺</div>
                                        <div class="o_kds_dash_station_pending">
                                            <span class="o_kds_dash_station_pending_num"
                                                  t-att-class="station.pending > 0 ? 'o_kds_dash_station_pending_num has-orders' : 'o_kds_dash_station_pending_num'"
                                                  t-esc="station.pending"/>
                                            <span class="o_kds_dash_station_pending_label">pendientes</span>
                                        </div>
                                    </div>
                                    <div class="o_kds_dash_station_name">
                                        <t t-esc="station.name"/>
                                        <t t-if="station.is_demo">
                                            <span class="o_kds_demo_badge"> DEMO</span>
                                        </t>
                                    </div>
                                    <div class="o_kds_dash_station_cats">
                                        <t t-if="station.show_all || !station.category_names.length">
                                            <span class="o_kds_dash_cat_all">Todas las categorías</span>
                                        </t>
                                        <t t-else="">
                                            <t t-foreach="station.category_names" t-as="cat" t-key="cat">
                                                <span class="o_kds_dash_cat_pill" t-esc="cat"/>
                                            </t>
                                        </t>
                                    </div>
                                </div>
                                <div class="o_kds_dash_station_actions">
                                    <button class="o_kds_dash_open_btn"
                                            t-on-click="() => this.openKds(station.id, station.access_token)">
                                        ▶ Abrir KDS
                                    </button>
                                    <button class="o_kds_dash_station_edit_btn"
                                            t-on-click="() => this.openStationForm(station.id)"
                                            title="Editar estación">✎</button>
                                    <button class="o_kds_dash_station_del_btn"
                                            t-if="!station.is_demo"
                                            t-on-click="() => this.confirmDeleteStation(station.id, station.name)"
                                            title="Eliminar estación">✕</button>
                                </div>
                            </div>
                        </t>

                        <!-- Empty state: no hay estaciones -->
                        <t t-if="state.stations.length === 0">
                            <div class="o_kds_dash_empty_stations">
                                <div class="o_kds_dash_empty_icon">📺</div>
                                <div class="o_kds_dash_empty_title">Sin estaciones configuradas</div>
                                <div class="o_kds_dash_empty_sub">
                                    Crea estaciones para filtrar órdenes por área de cocina
                                </div>
                                <t t-if="state.licenseValid">
                                    <button class="o_kds_dash_btn_primary"
                                            t-on-click="() => this.openStationForm()">
                                        + Nueva estación
                                    </button>
                                </t>
                                <t t-else="">
                                    <div class="o_kds_demo_lock_btn" title="Desbloquea en bitopolis.cc">
                                        🔒 Multi-estación — Versión completa en bitopolis.cc
                                    </div>
                                </t>
                            </div>
                        </t>

                    </div>
                </div>

                <!-- ========= CONFIGURACIÓN ========= -->
                <div class="o_kds_dash_section">
                    <div class="o_kds_dash_section_header">
                        <h2 class="o_kds_dash_section_title">⚙️ Configuración Global</h2>
                        <button class="o_kds_dash_section_action"
                                t-on-click="toggleConfigEditor">
                            <t t-if="state.showConfig">Cerrar ✕</t>
                            <t t-else="">Editar →</t>
                        </button>
                    </div>

                    <!-- Resumen de config (siempre visible) -->
                    <div class="o_kds_dash_config_strip">
                        <div class="o_kds_dash_config_items">
                            <t t-foreach="configSummaryItems" t-as="item" t-key="item.label">
                                <div class="o_kds_dash_config_item">
                                    <span t-esc="item.icon"/>
                                    <span><strong t-esc="item.label"/>: <t t-esc="item.value"/></span>
                                </div>
                            </t>
                        </div>
                        <div class="o_kds_dash_config_actions">
                            <button class="o_kds_dash_btn_secondary"
                                    t-on-click="openOrderHistory">
                                📋 Historial de órdenes
                            </button>
                        </div>
                    </div>

                    <!-- Editor inline de configuración -->
                    <div t-if="state.showConfig" class="o_kds_dash_config_editor">
                        <div class="o_kds_dash_config_grid">

                            <div t-att-class="'o_kds_dash_field' + (state.licenseValid ? '' : ' o_kds_demo_lock_field')">
                                <label>🟡 Minutos hasta Amarillo <t t-if="!state.licenseValid">🔒</t></label>
                                <input type="range" min="1" max="30"
                                       t-model.number="state.form.warn_minutes"
                                       t-att-disabled="!state.licenseValid"/>
                                <span class="o_kds_dash_field_value"
                                      t-esc="state.form.warn_minutes + ' min'"/>
                            </div>

                            <div t-att-class="'o_kds_dash_field' + (state.licenseValid ? '' : ' o_kds_demo_lock_field')">
                                <label>🔴 Minutos hasta Rojo <t t-if="!state.licenseValid">🔒</t></label>
                                <input type="range" min="2" max="60"
                                       t-model.number="state.form.danger_minutes"
                                       t-att-disabled="!state.licenseValid"/>
                                <span class="o_kds_dash_field_value"
                                      t-esc="state.form.danger_minutes + ' min'"/>
                            </div>

                            <div class="o_kds_dash_field">
                                <label>⏱ Polling de respaldo (seg)</label>
                                <input type="number" min="5" max="120"
                                       t-model.number="state.form.poll_interval"/>
                            </div>

                            <div t-if="state.licenseValid" class="o_kds_dash_field">
                                <label>↩ Órdenes en bandeja deshacer</label>
                                <input type="number" min="1" max="20"
                                       t-model.number="state.form.undo_count"/>
                            </div>
                            <div t-else="" class="o_kds_dash_field o_kds_demo_lock_field">
                                <label>↩ Órdenes en bandeja deshacer</label>
                                <div class="o_kds_demo_lock_inline">🔒 Solo versión completa</div>
                            </div>

                            <div class="o_kds_dash_field">
                                <label>🔔 Sonido en nueva orden</label>
                                <div class="o_kds_dash_toggle_row">
                                    <span t-esc="state.form.sound_enabled ? 'Activado' : 'Desactivado'"/>
                                    <button class="o_kds_dash_toggle"
                                            t-att-class="state.form.sound_enabled ? 'o_kds_dash_toggle on' : 'o_kds_dash_toggle'"
                                            t-on-click="() => state.form.sound_enabled = !state.form.sound_enabled">
                                        <div class="o_kds_dash_toggle_knob"/>
                                    </button>
                                </div>
                            </div>

                            <div class="o_kds_dash_field">
                                <label t-esc="volumeLabel"/>
                                <input type="range" min="0.1" max="1" step="0.1"
                                       t-model.number="state.form.sound_volume"/>
                                <span class="o_kds_dash_field_value"
                                      t-esc="Math.round((state.form.sound_volume || 1) * 100) + '%'"/>
                            </div>

                            <div t-att-class="'o_kds_dash_field o_kds_dash_field_full' + (state.licenseValid ? '' : ' o_kds_demo_lock_field')">
                                <label>🔡 Tamaño de fuente en pantalla <t t-if="!state.licenseValid"> 🔒</t></label>
                                <div class="o_kds_dash_font_size_row">
                                    <!-- Presets rápidos -->
                                    <t t-foreach="fontSizePresets" t-as="p" t-key="p.value">
                                        <button class="o_kds_dash_font_size_btn"
                                                t-att-class="{ 'o_kds_dash_font_size_active': state.form.font_size == p.value }"
                                                t-on-click="() => state.form.font_size = p.value">
                                            <span class="o_kds_dash_font_size_preview"
                                                  t-att-style="'font-size:' + Math.min(p.value, 28) + 'px'">#42</span>
                                            <span class="o_kds_dash_font_size_label">
                                                <t t-esc="p.label"/>
                                                <small t-esc="' (' + p.value + 'px)'"/>
                                            </span>
                                        </button>
                                    </t>
                                    <!-- Input manual -->
                                    <div class="o_kds_dash_font_size_custom">
                                        <span class="o_kds_dash_font_size_custom_label">Personalizado</span>
                                        <div class="o_kds_dash_font_size_custom_input">
                                            <input type="number" min="10" max="60" step="1"
                                                   t-model.number="state.form.font_size"/>
                                            <span class="o_kds_dash_font_size_px">px</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                        <div class="o_kds_dash_keys_section">
                            <div class="o_kds_dash_keys_header">
                                <span class="o_kds_dash_keys_title">⌨ Teclas Numpad</span>
                                <button class="o_kds_dash_keys_reset" t-on-click="() => this.resetKeys()">
                                    ↺ Default
                                </button>
                            </div>
                            <div class="o_kds_dash_keys_grid">
                                <t t-foreach="keyBindingRows" t-as="row" t-key="row.field">
                                    <div class="o_kds_dash_key_row"
                                         t-att-class="{ 'o_kds_dash_key_capturing': state.capturingFor === row.field }">
                                        <span class="o_kds_dash_key_icon" t-esc="row.icon"/>
                                        <span class="o_kds_dash_key_label" t-esc="row.label"/>
                                        <t t-if="state.capturingFor === row.field">
                                            <span class="o_kds_dash_key_waiting">Presiona una tecla… (Esc cancela)</span>
                                        </t>
                                        <t t-else="">
                                            <kbd class="o_kds_dash_key_kbd"
                                                 t-esc="keyLabel(state.form[row.field])"/>
                                        </t>
                                        <button class="o_kds_dash_key_btn"
                                                t-on-click="() => this.startCapture(row.field)">
                                            <t t-if="state.capturingFor === row.field">Cancelar</t>
                                            <t t-else="">Cambiar</t>
                                        </button>
                                    </div>
                                </t>
                            </div>
                        </div>

                        <div class="o_kds_dash_config_footer">
                            <span t-if="state.saved" class="o_kds_dash_saved_badge">
                                ✓ Configuración guardada
                            </span>
                            <button class="o_kds_dash_cancel_btn"
                                    t-on-click="toggleConfigEditor"
                                    t-att-disabled="state.saving">
                                Cancelar
                            </button>
                            <button class="o_kds_dash_save_btn"
                                    t-on-click="saveConfig"
                                    t-att-disabled="state.saving">
                                <t t-if="state.saving">Guardando...</t>
                                <t t-else="">✓ Guardar</t>
                            </button>
                        </div>
                    </div>
                </div>

            </t>
        </div>
    </div>
</t>

</templates>
