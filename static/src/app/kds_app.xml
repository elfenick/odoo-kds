<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="bitopolis_kds.KdsApp">
        <div class="o_kds_app" t-att-style="fontSizeStyle">

            <!-- ===================== HEADER ========================= -->
            <header class="o_kds_header">
                <div class="o_kds_brand">
                    <span class="o_kds_logo">🍳</span>
                    <div class="o_kds_brand_text">
                        <span class="o_kds_title">Bitópolis KDS</span>
                        <span t-if="state.stationLabel"
                              class="o_kds_station_badge"
                              t-esc="state.stationLabel"/>
                    </div>
                </div>

                <div class="o_kds_stats">
                    <div class="o_kds_stat">
                        <span class="o_kds_stat_value" t-esc="pendingCount"/>
                        <span class="o_kds_stat_label">Pendientes</span>
                    </div>
                    <div class="o_kds_stat">
                        <span class="o_kds_stat_value" t-esc="currentTimeLabel"/>
                        <span class="o_kds_stat_label">Hora</span>
                    </div>
                    <div class="o_kds_stat"
                         t-att-class="{ 'o_kds_disconnected': !state.connected }">
                        <span class="o_kds_stat_dot"/>
                        <span class="o_kds_stat_label">
                            <t t-if="state.connected">Conectado</t>
                            <t t-else="">Reconectando</t>
                        </span>
                    </div>
                </div>

                <div class="o_kds_header_actions">
                    <!-- Solo la orden seleccionada (sin indicador de teclas) -->
                    <div class="o_kds_nav_indicator"
                         t-att-class="{ 'o_kds_nav_active': pendingCount > 0 }">
                        <span class="o_kds_nav_value" t-esc="selectedOrderLabel"/>
                    </div>

                    <!-- Bandeja deshacer -->
                    <button class="o_kds_header_btn"
                            t-att-class="{ 'o_kds_header_btn_active': state.showUndoTray }"
                            t-on-click="() => state.showUndoTray = !state.showUndoTray"
                            title="Deshacer">
                        ↩
                        <span t-if="state.recentlyDone.length > 0"
                              class="o_kds_header_btn_badge"
                              t-esc="state.recentlyDone.length"/>
                    </button>
                </div>
            </header>

            <!-- ========= BANNER DESCONEXIÓN =================== -->
            <t t-if="!state.connected">
                <div class="o_kds_disconnection_banner">
                    ⚠️ Sin conexión — reconectando...
                </div>
            </t>


            <!-- ========== ESTACIÓN ELIMINADA/INVÁLIDA ============= -->
            <t t-if="state.stationInvalid">
                <div class="o_kds_license_block">
                    <div class="o_kds_license_block_box">
                        <div class="o_kds_license_block_icon">📺</div>
                        <h2>KDS no disponible</h2>
                        <p>Esta pantalla fue eliminada o desactivada.</p>
                        <p class="o_kds_license_block_hint">
                            Contacta al administrador para obtener<br/>
                            un nuevo enlace de acceso.
                        </p>
                    </div>
                </div>
            </t>


            <t t-if="!state.licenseValid and !state.stationInvalid">
                <div class="o_kds_license_block">
                    <div class="o_kds_license_block_box">
                        <div class="o_kds_license_block_icon">🔒</div>
                        <h2>Licencia requerida</h2>
                        <p>Este módulo requiere una licencia válida para funcionar.</p>
                        <p>Contacta a <strong>bitopolis.cc</strong> para adquirir tu licencia.</p>
                        <p class="o_kds_license_block_hint">
                            Actívala en <strong>Cocina → Licencia → Validar</strong>
                        </p>
                    </div>
                </div>
            </t>


            <!-- =================== UNDO TRAY ======================== -->
            <div t-if="state.showUndoTray and state.recentlyDone.length > 0"
                 class="o_kds_undo_tray">
                <div class="o_kds_undo_tray_label">↩ Órdenes completadas</div>
                <div class="o_kds_undo_list">
                    <t t-foreach="state.recentlyDone" t-as="order" t-key="order.done_id || order.id">
                        <div class="o_kds_undo_card">
                            <span class="o_kds_undo_num">
                                #<t t-esc="order.tracking_number or order.name"/>
                            </span>
                            <span t-if="order.table_name"
                                  class="o_kds_undo_table"
                                  t-esc="'Mesa ' + order.table_name"/>
                            <button class="o_kds_undo_btn"
                                    t-on-click="() => this.reopenOrderWithLimit(order.done_id || order.id)">
                                ↩ Deshacer
                            </button>
                        </div>
                    </t>
                </div>
            </div>

            <t t-if="state.licenseValid">
            <!-- ==================== GRID ============================ -->
            <main class="o_kds_grid">
                <t t-if="state.orders.length === 0">
                    <div class="o_kds_empty">
                        <div class="o_kds_empty_icon">🍽️</div>
                        <div class="o_kds_empty_title">Todo al día</div>
                        <div class="o_kds_empty_subtitle">
                            Las nuevas órdenes aparecerán aquí automáticamente.
                        </div>
                    </div>
                </t>
                <t t-else="">
                    <t t-foreach="state.orders" t-as="order" t-key="order.id">
                        <OrderCard
                            order="order"
                            now="state.now"
                            warnSeconds="state.warnSeconds"
                            dangerSeconds="state.dangerSeconds"
                            isSelected="order.id === selectedOrderId"
                            onComplete.bind="completeOrder"/>
                    </t>
                </t>
            </main>

            <!-- =================== FOOTER =========================== -->
            <footer class="o_kds_footer">
                <span class="o_kds_footer_hint">
                    Touch: <b>Listo</b> ·
                    <b><t t-esc="keyLabel(state.bindings.key_nav_up)"/></b> /
                    <b><t t-esc="keyLabel(state.bindings.key_nav_down)"/></b> navegar ·
                    <b><t t-esc="keyLabel(state.bindings.key_complete)"/></b> completar ·
                    <b><t t-esc="keyLabel(state.bindings.key_undo)"/></b> deshacer
                </span>
            </footer>

        </t>
        </div>
    </t>

</templates>
